{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile with role-based access.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Firebase Auth UID" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "role": { "type": "string", "enum": ["patient", "doctor", "front_desk"] },
        "specialization": { "type": "string", "description": "Only for doctors" }
      },
      "required": ["uid", "email", "role"]
    },
    "Appointment": {
      "title": "Appointment",
      "description": "A scheduled medical appointment.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "patientId": { "type": "string" },
        "patientName": { "type": "string" },
        "doctorId": { "type": "string" },
        "doctorName": { "type": "string" },
        "startTime": { "type": "string", "format": "date-time" },
        "endTime": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["New", "Confirmed", "Upcoming", "Checked In", "Completed", "No Show"] },
        "notes": { "type": "string" }
      },
      "required": ["patientId", "doctorId", "startTime", "endTime", "status"]
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": "User",
      "description": "User profiles"
    },
    "appointments/{appointmentId}": {
      "schema": "Appointment",
      "description": "Clinic appointments"
    }
  }
}
